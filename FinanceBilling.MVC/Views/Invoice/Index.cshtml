@model List<FinanceBilling.MVC.Models.InvoiceViewModel>

<style>

    /* Invoice Dashboard Banner Styling */
    .invoice-banner {
        background: #f1f5f9;
        color: #111827;
        border: 1px solid #cbd5e1;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    /* Dashboard Card Styling */
    .dashboard-card {
        background: #f1f5f9;
        color: #111827;
        border: 1px solid #cbd5e1;
        border-radius: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,.05);
        transition: .3s;
    }

        /* Dashboard Card Hover Effect */
        .dashboard-card:hover {
            transform: translateY(-5px);
        }

        /* Dashboard Card Text Styling */
        .dashboard-card h2,
        .dashboard-card h5,
        .dashboard-card p {
            color: #111827;
        }

    /* Table Row Hover Effect */
    .table-hover tbody tr:hover {
        background-color: #f8fafc;
    }

    /* Summary Card Header Styling */
    .summary-header {
        background: #f1f5f9;
        color: #111827;
        border-bottom: 1px solid #cbd5e1;
        font-weight: 600;
    }

</style>

<!-- Dashboard Logo -->
<div class="text-center mb-4">

    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"
         width="90" />

</div>

<!-- Page Header and Create Invoice Button -->
<div class="d-flex justify-content-between align-items-center mb-4">

    <h2 class="fw-bold">
        Invoice Management
    </h2>

    <!-- Show Create Button Only For Admin and Accountant -->
    @if (Context.Session.GetString("Role") == "1" ||
         Context.Session.GetString("Role") == "2")
    {
        <a asp-action="Create"
               class="btn btn-outline-success">

            + Create Invoice

        </a>
    }

</div>

<!-- Invoice Tracking Banner -->
<div class="invoice-banner shadow mb-4 text-center">

    <h3>📄 Invoice Tracking Dashboard</h3>

    <p class="mb-0">
        Manage invoices, monitor payment status and track customer billing efficiently.
    </p>

</div>

<!-- Invoice List Card -->
<div class="card shadow">

    <div class="card-body">

        <!-- Invoice Table -->
        <table class="table table-hover table-striped">

            <thead class="table-light">

                <tr>
                    <th>Invoice ID</th>
                    <th>Invoice No</th>
                    <th>Customer</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>

            </thead>

            <tbody>

                <!-- Loop Through Invoice Records -->
                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.InvoiceId</td>

                        <td>@item.InvoiceNumber</td>

                        <td>@item.CustomerName</td>

                        <td>
                            ₹@item.TotalAmount
                        </td>

                        <td>

                            <!-- Display Status Badge Based On Invoice Status -->
                            @if (item.Status == "Paid" ||
                                 item.Status == "Completed" ||
                                 item.Status == "Successful")
                            {
                                <span class="badge bg-success">
                                    @item.Status
                                </span>
                            }
                            else if (item.Status == "Partially Paid")
                            {
                                <span class="badge bg-warning text-dark">
                                    @item.Status
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    @item.Status
                                </span>
                            }

                        </td>

                        <td>

                            <!-- View Invoice Button -->
                            <a asp-action="Details"
                                   asp-route-id="@item.InvoiceId"
                                   class="btn btn-info btn-sm">

                                View

                            </a>

                            <!-- Edit Button For Admin and Accountant -->
                            @if (Context.Session.GetString("Role") == "1" ||
                                 Context.Session.GetString("Role") == "2")
                            {
                                <a asp-action="Edit"
                                       asp-route-id="@item.InvoiceId"
                                       class="btn btn-warning btn-sm">

                                    Edit

                                </a>
                            }

                            <!-- Delete Button Only For Admin -->
                            @if (Context.Session.GetString("Role") == "1")
                            {
                                <a asp-action="Delete"
                                       asp-route-id="@item.InvoiceId"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Are you sure you want to delete this invoice?')">

                                    Delete

                                </a>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<!-- Invoice Summary Section -->
<div class="card shadow mt-4">

    <div class="card-header summary-header">

        📊 Invoice Summary

    </div>

    <div class="card-body">

        <div class="row text-center">

            <!-- Total Invoices Count -->
            <div class="col-md-4">

                <h3 class="text-primary">
                    @Model.Count()
                </h3>

                <p>Total Invoices</p>

            </div>

            <!-- Paid Invoices Count -->
            <div class="col-md-4">

                <h3 class="text-success">

                    @Model.Count(x =>
                        x.Status == "Paid" ||
                        x.Status == "Completed" ||
                        x.Status == "Successful")

                </h3>

                <p>Paid Invoices</p>

            </div>

            <!-- Pending Invoices Count -->
            <div class="col-md-4">

                <h3 class="text-danger">

                    @Model.Count(x => x.Status == "Pending")

                </h3>

                <p>Pending Invoices</p>

            </div>

        </div>

    </div>

</div>

<!-- Back To Home Button -->
<div class="mt-4">

    <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-outline-secondary">

        🏠 Back to Home

    </a>

</div>