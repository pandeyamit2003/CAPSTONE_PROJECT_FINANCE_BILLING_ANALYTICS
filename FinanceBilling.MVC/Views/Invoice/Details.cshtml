@model FinanceBilling.MVC.Models.InvoiceViewModel

<!-- Main Card Container -->
<div class="card shadow">

    <!-- Card Header -->
    <div class="card-header bg-primary text-white">

        <h4 class="mb-0">
            Invoice Details
        </h4>

    </div>

    <div class="card-body">

        <!-- Invoice Details Table -->
        <table class="table table-bordered">

            <!-- Invoice ID -->
            <tr>
                <th width="30%">Invoice ID</th>
                <td>@Model.InvoiceId</td>
            </tr>

            <!-- Invoice Number -->
            <tr>
                <th width="30%">Invoice Number</th>
                <td>@Model.InvoiceNumber</td>
            </tr>

            <!-- Customer Name -->
            <tr>
                <th>Customer Name</th>
                <td>@Model.CustomerName</td>
            </tr>

            <!-- Invoice Date -->
            <tr>
                <th>Invoice Date</th>
                <td>@Model.InvoiceDate.ToShortDateString()</td>
            </tr>

            <!-- Total Amount -->
            <tr>
                <th>Total Amount</th>
                <td>₹@Model.TotalAmount</td>
            </tr>

            <!-- Invoice Status -->
            <tr>
                <th>Status</th>
                <td>

                    <!-- Check Status and Display Badge -->
                    @if (Model.Status == "Paid" || Model.Status == "Completed" || Model.Status == "Successful")
                    {
                        <span class="badge bg-success">
                            @Model.Status
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            @Model.Status
                        </span>
                    }

                </td>
            </tr>

        </table>

        <!-- Navigation Button Section -->
        <div class="mt-4">

            <!-- Back Button -->
            <a asp-action="Index"
                   class="btn text-white"
                   style="background:linear-gradient(45deg,#6f42c1,#0dcaf0);border:none;">

                ← Back

            </a>

        </div>

    </div>

</div>