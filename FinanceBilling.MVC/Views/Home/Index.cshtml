@{
    // Set page title
    ViewData["Title"] = "Home";
}

<style>

    /* Hero Section Styling */
    .hero-section {
        background: linear-gradient(135deg,#e3f2fd,#ffffff);
        border-radius: 20px;
        padding: 50px;
        box-shadow: 0px 5px 20px rgba(0,0,0,0.1);
    }

    /* Feature Card Styling */
    .feature-card {
        transition: 0.3s;
        border: none;
        border-radius: 15px;
    }

        /* Feature Card Hover Effect */
        .feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0px 10px 25px rgba(0,0,0,0.2);
        }

</style>

<!-- Hero Section -->
<div class="hero-section text-center">

    <!-- Application Logo -->
    <img src="https://cdn-icons-png.flaticon.com/512/2489/2489756.png"
         width="180"
         class="img-fluid mb-3" />

    <!-- Main Heading -->
    <h1 class="display-3 fw-bold text-primary">
        💰 Finance Billing Analytics
    </h1>

    <!-- Application Description -->
    <p class="lead text-secondary mt-3">
        Smart Invoice Management, Payment Tracking,
        Revenue Analytics and Business Insights
    </p>

    <!-- Navigation Buttons -->
    <div class="mt-4">

        <!-- Open Dashboard Button -->
        <a asp-controller="Dashboard"
               asp-action="Index"
               class="btn btn-primary btn-lg me-3">

            📊 Open Dashboard

        </a>

        <!-- View Invoices Button -->
        <a asp-controller="Invoice"
               asp-action="Index"
               class="btn btn-success btn-lg">

            📄 View Invoices

        </a>

    </div>

</div>

<!-- Feature Cards Section -->

<div class="row mt-5">

    <!-- Invoice Feature Card -->
    <div class="col-md-4">

        <div class="card shadow feature-card">

            <div class="card-body text-center">

                <h1>📄</h1>

                <h3>Invoices</h3>

                <p>
                    Create, Edit and Track Customer Invoices
                </p>

            </div>

        </div>

    </div>

    <!-- Payment Feature Card -->
    <div class="col-md-4">

        <div class="card shadow feature-card">

            <div class="card-body text-center">

                <h1>💳</h1>

                <h3>Payments</h3>

                <p>
                    Manage and Track Customer Payments
                </p>

            </div>

        </div>

    </div>

    <!-- Analytics Feature Card -->
    <div class="col-md-4">

        <div class="card shadow feature-card">

            <div class="card-body text-center">

                <h1>📈</h1>

                <h3>Analytics</h3>

                <p>
                    Monitor Revenue and Collection Performance
                </p>

            </div>

        </div>

    </div>

</div>

<!-- Key Features Section -->

<div class="card shadow-lg mt-5 border-0">

    <div class="card-body text-center">

        <!-- Section Heading -->
        <h2 class="text-primary">
            🚀 Key Features
        </h2>

        <hr />

        <!-- Features List -->
        <div class="row">

            <div class="col-md-3">
                📄 Invoice Management
            </div>

            <div class="col-md-3">
                💳 Payment Tracking
            </div>

            <div class="col-md-3">
                📊 Revenue Dashboard
            </div>

            <div class="col-md-3">
                🔐 Role Based Access
            </div>

        </div>

    </div>

</div>

<!-- About Section -->

<div class="card shadow-lg mt-5 border-0">

    <div class="card-body text-center">

        <!-- About Heading -->
        <h2 class="text-success">
            🌟 Why Finance Billing Analytics?
        </h2>

        <!-- About Description -->
        <p class="mt-3">

            This system helps businesses manage invoices,
            track payments, monitor pending amounts,
            and analyze revenue performance efficiently.

        </p>

    </div>

</div>