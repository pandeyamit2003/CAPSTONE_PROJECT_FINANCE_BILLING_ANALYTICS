@model FinanceBilling.MVC.Models.ForgotPasswordViewModel

<!-- Display error message returned from Controller -->
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<!-- Main Forgot Password Container -->
<div class="container mt-5 p-4 rounded shadow-sm"
     style="background-color:#f8f9fa;">

    <!-- Page Heading -->
    <h2>Forgot Password</h2>

    <!-- Form sends Email to MVC Controller -->
    <form asp-action="ForgotPassword" method="post">

        <!-- Email Input -->
        <div class="mb-3">

            <!-- Email Label -->
            <label>Email Address</label>

            <!-- User enters registered email -->
            <input asp-for="Email"
                   class="form-control" />

            <!-- Validation message for Email field -->
            <span asp-validation-for="Email"
                  class="text-danger"></span>

        </div>

        <!-- Submit Button -->
        <button type="submit"
                class="btn btn-primary">

            Send OTP

        </button>

        <!-- Navigate back to Login Page -->
        <a asp-action="Login"
               class="btn"
               style="background-color:#e9ecef;color:black;border:1px solid #dee2e6;">
            Back
        </a>

    </form>

    <!-- Client-side Validation Scripts -->
    @section Scripts
    {
        <partial name="_ValidationScriptsPartial" />
    }

</div>