@model FinanceBilling.MVC.Models.LoginViewModel

@{
    // No Layout page used for Login screen
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <!-- Page Title -->
    <title>Finance Billing Login</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>

            /*  PAGE BACKGROUND  */
            body {
                height: 100vh;
                background: linear-gradient(135deg,#f8fafc,#e2e8f0,#dbeafe);                
                background-size: 400% 400%;
                animation: gradientBG 12s ease infinite;
                display: flex;
                justify-content: center;
                align-items: center;
                overflow: hidden;
            }

            /* Animated Gradient Background */
            @@keyframes gradientBG {
                0% {
                    background-position: 0% 50%;
                }

                50% {
                    background-position: 100% 50%;
                }

                100% {
                    background-position: 0% 50%;
                }
            }

            /* Main Login Container */
            .login-container {
                width: 1050px;
                height: 600px;
                background: rgba(255,255,255,0.12);
                backdrop-filter: blur(15px);
                border-radius: 25px;
                overflow: hidden;
                box-shadow: 0 20px 50px rgba(0,0,0,.35);
            }

            /* Left Information Panel */
            .left-panel {
                background: url('https://images.unsplash.com/photo-1554224155-6726b3ff858f') center center/cover;
                height: 100%;
                position: relative;
            }

            /* Dark Overlay on Background Image */
            .overlay {
                background: rgba(0,0,0,.65);
                height: 100%;
                color: white;
                padding: 50px;
            }

            /* Login Form Panel */
            .right-panel {
                background: white;
                padding: 50px;
            }

            /* Company Logo */
            .logo {
                font-size: 60px;
            }

            /* Login Title */
            .login-title {
                color: #2563eb;
                font-size: 40px;
                font-weight: bold;
            }

            /* Input Fields */
            .form-control {
                height: 55px;
                border-radius: 15px;
                font-size: 16px;
            }

            /* Login Button */
            .btn-login {
                height: 55px;
                border-radius: 15px;
                font-size: 20px;
                font-weight: bold;
                border: none;
                background: linear-gradient(45deg,#2563eb,#7c3aed);
                transition: .3s;
            }

            /* Floating Finance Icons */
            .floating-money {
                position: absolute;
                top: 80px;
                left: 100px;
                font-size: 55px;
                animation: float 4s infinite;
            }

            .floating-chart {
                position: absolute;
                top: 150px;
                right: 120px;
                font-size: 55px;
            }

            .floating-card {
                position: absolute;
                bottom: 120px;
                left: 150px;
                font-size: 55px;
            }

            /* Validation Message Styling */
            .field-validation-error {
                color: red;
                font-size: 14px;
                font-weight: bold;
            }

    </style>

</head>

<body>

    <!-- Main Login Container -->
    <div class="login-container">

        <div class="row h-100">

            <!-- Left Information Section -->
            <div class="col-md-6 left-panel">

                <div class="overlay">

                    <!-- Application Heading -->
                    <h1>
                        💰 Finance Billing &     
                           Analytics
                    </h1>

                    <!-- Application Description -->
                    <p>
                        Smart Financial Management Platform
                    </p>

                    <!-- Feature List -->
                    <div class="mt-4">
                        <div class="feature-item mb-3">
                            📄 Invoice Management
                        </div>

                        <div class="feature-item mb-3">
                            💳 Payment Tracking
                        </div>

                        <div class="feature-item mb-3">
                            📊 Revenue Analytics
                        </div>

                        <div class="feature-item mb-3">
                            🔐 Secure Role Based Access
                        </div>

                        <div class="feature-item mb-3">
                            ⚡ Real-Time Dashboard
                        </div>

                    </div>

                </div>

            </div>

            <!-- Right Login Form Section -->
            <div class="col-md-6 right-panel">

                <div class="text-center">

                    <!-- Application Logo -->
                    <div class="logo">
                        🏦
                    </div>

                    <!-- Welcome Heading -->
                    <h2 class="login-title">
                        Welcome Back
                    </h2>

                </div>

                <!-- Login Form -->
                <form asp-action="Login" method="post">

                    <!-- Validation Summary -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger">
                    </div>

                    <!-- Username Field -->
                    <div class="mb-3">

                        <label class="fw-bold">
                            Username
                        </label>

                        <input asp-for="UserName"
                               class="form-control"
                               autocomplete="off" />

                        <span asp-validation-for="UserName"
                              class="text-danger"></span>

                    </div>

                    <!-- Password Field -->
                    <div class="mb-3">

                        <label class="fw-bold">
                            Password
                        </label>

                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               autocomplete="new-password" />

                        <span asp-validation-for="Password"
                              class="text-danger"></span>

                    </div>

                    <!-- API Error Message -->
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <!-- Login Button -->
                    <button type="submit"
                            class="btn btn-login text-white w-100">
                        🔐 Login
                    </button>

                    <!-- Forgot Password Link -->
                    <div class="mt-3">

                        <a asp-controller="Auth"
                               asp-action="ForgotPassword">

                            Forgot Password?

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <!-- jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- jQuery Validation -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

    <!-- Unobtrusive Validation -->
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>