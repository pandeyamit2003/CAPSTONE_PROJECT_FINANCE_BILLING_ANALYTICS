@model FinanceBilling.MVC.Models.ResetPasswordViewModel

<!-- Main Reset Password Container -->
<div class="container mt-5 p-4 rounded shadow-sm"
     style="background-color:#f8f9fa;">

    <!-- Page Heading -->
    <h2>Reset Password</h2>

    <!-- Form submits new password to MVC Controller -->
    <form asp-action="ResetPassword" method="post">

        <!-- Hidden token received after OTP verification -->
        <input asp-for="Token"
               type="hidden" />

        <!-- New Password Field -->
        <div class="mb-3">

            <!-- New Password Label -->
            <label>New Password</label>

            <!-- User enters new password -->
            <input asp-for="NewPassword"
                   type="password"
                   class="form-control" />

            <!-- Validation message for New Password -->
            <span asp-validation-for="NewPassword"
                  class="text-danger"></span>

        </div>

        <!-- Reset Password Button -->
        <button type="submit"
                class="btn btn-danger">

            Reset Password

        </button>

        <!-- Navigate back to OTP Verification Page -->
        <a asp-action="VerifyOtp"
               class="btn"
               style="background-color:#e9ecef;color:black;border:1px solid #dee2e6;">
            Back
        </a>

    </form>

    <!-- Client-side Validation Scripts -->
    @section Scripts
    {
        <partial name="_ValidationScriptsPartial" />
    }

</div>