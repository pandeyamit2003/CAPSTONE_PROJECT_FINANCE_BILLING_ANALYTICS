@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Finance Billing Analytics</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinanceBilling.MVC.styles.css" asp-append-version="true" />
</head>
<body>

    @if (Context.Session.GetString("JWToken") != null)
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">

            <div class="container">

                <a class="navbar-brand fw-bold"
                       asp-controller="Dashboard"
                       asp-action="Index">

                    💰 Finance Billing Analytics

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarContent">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link nav-home"
                                   asp-controller="Home"
                                   asp-action="Index">
                                🏠 Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-dashboard"
                                   asp-controller="Dashboard"
                                   asp-action="Index">
                                📊 Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-invoice"
                                   asp-controller="Invoice"
                                   asp-action="Index">
                                📄 Invoices
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-payment"
                                   asp-controller="Payment"
                                   asp-action="Index">
                                💳 Payments
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-logout"
                                   asp-controller="Auth"
                                   asp-action="Logout">
                                🚪 Logout
                            </a>
                        </li>

                    </ul>

                </div>

            </div>

        </nav>
    }

    <div class="container mt-4 content-wrapper">

        <main role="main">
            @RenderBody()
        </main>

    </div>

    

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>